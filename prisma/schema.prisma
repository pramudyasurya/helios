// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Run {
  id          String    @id
  startingUrl String
  status      String
  summary     String
  createdAt   DateTime  @default(now())
  finishedAt  DateTime?
  durationMs  Int?
  finalUrl    String?
  title       String?
  description String?

  trail     Json
  checks    Json
  artifacts Json?
  report    Json?

  brokenImages   Json?
  consoleErrors  Json?
  failedRequests Json?
  loadMetrics    Json?
  evidence       Evidence[]
  pageResults    PageResult[]

  updatedAt DateTime @default(now()) @updatedAt
}

enum EvidenceType {
  image
  console
  network
}

enum EvidenceStatus {
  open
  resolved
  ignored
}

model Evidence {
  id          String         @id @default(uuid())
  runId       String
  run         Run            @relation(fields: [runId], references: [id], onDelete: Cascade)
  type        EvidenceType
  content     String
  pageUrl     String
  resourceUrl String?
  status      EvidenceStatus @default(open)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model PageResult {
  id             String  @id @default(uuid())
  runId          String
  run            Run     @relation(fields: [runId], references: [id], onDelete: Cascade)
  url            String
  depth          Int
  status         String
  statusCode     Int?
  finalUrl       String?
  title          String?
  description    String?
  durationMs     Int?
  artifacts      Json?
  brokenImages   Json?
  consoleErrors  Json?
  failedRequests Json?
  loadMetrics    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
